project Euler_Lib is
   for Source_Dirs use ("src");
   for Object_Dir  use "obj";
   for Library_Dir use "lib";

   for Library_Name use "euler";
   for Library_Kind use "dynamic";  

   package Main is
      for Source_Dirs use (".");
      for Main use ("maineuler.adb");  
   end Main;     
end Euler_Lib;